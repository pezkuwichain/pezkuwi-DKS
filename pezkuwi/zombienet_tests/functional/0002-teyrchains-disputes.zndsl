Description: Disputes initiation, conclusion and lag
Network: ./0002-teyrchains-disputes.toml
Creds: config

# Check authority status and peers.
alice: reports node_roles is 4
bob: reports node_roles is 4
charlie: reports node_roles is 4
dave: reports node_roles is 4
eve: reports node_roles is 4
ferdie: reports node_roles is 4
one: reports node_roles is 4
two: reports node_roles is 4

# Ensure teyrchains are registered.
alice: teyrchain 2000 is registered within 30 seconds
bob: teyrchain 2001 is registered within 30 seconds
charlie: teyrchain 2002 is registered within 30 seconds
dave: teyrchain 2003 is registered within 30 seconds

# Ensure teyrchains made progress.
alice: teyrchain 2000 block height is at least 10 within 200 seconds
alice: teyrchain 2001 block height is at least 10 within 200 seconds
alice: teyrchain 2002 block height is at least 10 within 200 seconds
alice: teyrchain 2003 block height is at least 10 within 200 seconds

# Check if disputes are initiated and concluded.
# TODO: check if disputes are concluded faster than initiated.
eve: reports polkadot_teyrchain_candidate_disputes_total is at least 10 within 15 seconds
eve: reports polkadot_teyrchain_candidate_dispute_concluded{validity="valid"} is at least 10 within 15 seconds
eve: reports polkadot_teyrchain_candidate_dispute_concluded{validity="invalid"} is 0 within 15 seconds

alice: system event contains "There is an offence reported" within 60 seconds

# Check lag - approval
alice: reports polkadot_teyrchain_approval_checking_finality_lag is 0 within 120 seconds
bob: reports polkadot_teyrchain_approval_checking_finality_lag is 0 within 120 seconds
charlie: reports polkadot_teyrchain_approval_checking_finality_lag is 0 within 120 seconds
dave: reports polkadot_teyrchain_approval_checking_finality_lag is 0 within 120 seconds
ferdie: reports polkadot_teyrchain_approval_checking_finality_lag is 0 within 120 seconds
eve: reports polkadot_teyrchain_approval_checking_finality_lag is 0 within 120 seconds
one: reports polkadot_teyrchain_approval_checking_finality_lag is 0 within 120 seconds
two: reports polkadot_teyrchain_approval_checking_finality_lag is 0 within 120 seconds

# Check lag - dispute conclusion
alice: reports polkadot_teyrchain_disputes_finality_lag is 0 within 120 seconds
bob: reports polkadot_teyrchain_disputes_finality_lag is 0 within 120 seconds
charlie: reports polkadot_teyrchain_disputes_finality_lag is 0 within 120 seconds
dave: reports polkadot_teyrchain_disputes_finality_lag is 0 within 120 seconds
ferdie: reports polkadot_teyrchain_disputes_finality_lag is 0 within 120 seconds
eve: reports polkadot_teyrchain_disputes_finality_lag is 0 within 120 seconds
one: reports polkadot_teyrchain_disputes_finality_lag is 0 within 120 seconds
two: reports polkadot_teyrchain_disputes_finality_lag is 0 within 120 seconds

# Check participating in the losing side of a dispute logged
alice: log line contains "Voted against a candidate that was concluded valid." within 180 seconds
